# CustoMate frontend — Hostinger Apache config

# Enforce HTTPS
RewriteEngine On
RewriteCond %{HTTPS} !=on
RewriteRule ^(.*)$ https://%{HTTP_HOST}/$1 [R=301,L]

# SPA fallback — every non-file/non-dir request goes to index.html
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ index.html [L]

# Correct MIME types for 3D model assets
AddType model/gltf-binary  .glb
AddType model/gltf+json    .gltf
AddType image/webp         .webp

# Cache hashed asset bundles aggressively (Vite renames them on every build)
<IfModule mod_headers.c>
  <FilesMatch "\.(js|css|woff2|woff|ttf|glb|png|jpg|jpeg|webp|svg)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  # Never cache index.html — it must always pick up the latest asset hashes
  <FilesMatch "index\.html$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
  </FilesMatch>
</IfModule>

# Gzip compression
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/javascript application/javascript application/json image/svg+xml
</IfModule>
