# Copy this to .env.local for development, or set these in your hosting
# provider's environment-variable UI for production.

# Backend API base URL. Include the /api suffix.
# Dev:  http://localhost:4000/api
# Prod: https://api.your-domain.com/api
VITE_API_BASE_URL=http://localhost:4000/api

# Optional — Sentry DSN for frontend error tracking
# Get this from https://sentry.io after creating a project
VITE_SENTRY_DSN=

# Optional — Google client ID for Google OAuth Sign-In
VITE_GOOGLE_CLIENT_ID=

# Optional — Analytics
# VITE_GA_MEASUREMENT_ID=G-XXXXXXXX
# VITE_PLAUSIBLE_DOMAIN=your-domain.com
