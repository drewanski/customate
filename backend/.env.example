# Backend environment variables. Copy to backend/.env and fill in real values.

# ─── Runtime ────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=4000

# ─── Database ───────────────────────────────────────────────────────────────
# MongoDB Atlas connection string. NEVER commit the real one.
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>/<db>?retryWrites=true&w=majority

# ─── Auth ───────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
# Must be at least 32 characters in production.
JWT_SECRET=

# ─── CORS / frontend URL ────────────────────────────────────────────────────
# The exact origin of your deployed frontend. CORS is locked to this in prod.
FRONTEND_URL=https://your-domain.com

# ─── Email (SMTP for OTP + password reset) ──────────────────────────────────
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# ─── Google OAuth ───────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=

# ─── Cloudinary (image uploads) ─────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── PayMongo (Philippine payments) ─────────────────────────────────────────
# Production: use sk_live_* / pk_live_*. Never commit the secret key.
PAYMONGO_SECRET_KEY=
PAYMONGO_PUBLIC_KEY=
PAYMONGO_WEBHOOK_SECRET=

# ─── SMS (Semaphore, optional) ──────────────────────────────────────────────
SEMAPHORE_API_KEY=
SEMAPHORE_SENDER_NAME=

# ─── AI providers (optional) ────────────────────────────────────────────────
# The LLM service tries Ollama first (FREE, local), then Gemini, then a
# rule-based static fallback. Leave OLLAMA_URL blank to skip local-first.
GEMINI_API_KEY=
OPENAI_API_KEY=

# ─── Local LLM (Ollama) ─────────────────────────────────────────────────────
# Install: curl -fsSL https://ollama.com/install.sh | sh
# Pull model: ollama pull llama3.1:8b   (or phi-3.5 for a smaller model)
# Start service: ollama serve   (or it runs in background on Linux)
# Then point OLLAMA_URL at the host. Leave blank to disable.
OLLAMA_URL=
OLLAMA_TEXT_MODEL=llama3.1:8b

# Models for fallback to Gemini when Ollama not available
AI_TEXT_MODEL=gemini-2.5-flash
AI_IMAGE_MODEL=gemini-2.5-flash-image-preview

# Set to "true" to disable the persistent MongoDB AI cache (debugging only)
AI_DISABLE_CACHE=
