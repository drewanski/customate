# Frontend production environment.
# Copy to .env.production and fill in real values for deployment.
# Vite only exposes vars prefixed with VITE_ to the client bundle.

# Public API base URL (where your Express/Mongo backend is hosted)
VITE_API_BASE_URL=https://api.your-domain.com/api

# Optional: socket.io URL (defaults to VITE_API_BASE_URL origin)
# VITE_SOCKET_URL=https://api.your-domain.com

# Optional: Google OAuth client ID (must match backend GOOGLE_CLIENT_ID)
# VITE_GOOGLE_CLIENT_ID=

# Optional: PayMongo public key for client-side payment widgets
# VITE_PAYMONGO_PUBLIC_KEY=

# Optional: Sentry DSN for frontend error tracking
# VITE_SENTRY_DSN=
